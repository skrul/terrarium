FROM ubuntu:24.04

# Avoid interactive prompts during package install
ENV DEBIAN_FRONTEND=noninteractive

# Install essential dev tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    build-essential \
    sudo \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 LTS (required for MCP server)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create terrarium user with passwordless sudo
RUN useradd -m -s /bin/bash terrarium \
    && echo "terrarium ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/terrarium \
    && chmod 0440 /etc/sudoers.d/terrarium

# Copy TERRARIUM.md orientation file
COPY desktop/src-tauri/TERRARIUM.md /etc/terrarium/TERRARIUM.md
RUN chmod 444 /etc/terrarium/TERRARIUM.md

# Copy MCP server bundle
COPY mcp-server/dist/terrarium-mcp.js /opt/terrarium/mcp-server/terrarium-mcp.js
RUN chmod +x /opt/terrarium/mcp-server/terrarium-mcp.js

# Create state directory (writable by terrarium user)
RUN chown terrarium:terrarium /etc/terrarium

# Create workspace directory
RUN mkdir -p /home/terrarium/workspace && chown terrarium:terrarium /home/terrarium/workspace

# Install browser proxy script (forwards open-url requests to host API)
COPY desktop/src-tauri/scripts/host-open /usr/local/bin/host-open
RUN chmod +x /usr/local/bin/host-open

USER terrarium

# Install Claude Code via native installer (installs to ~/.local/bin/claude)
RUN curl -fsSL https://claude.ai/install.sh | bash

# Ensure ~/.local/bin is in PATH for all shell types (login, interactive, SSH)
RUN echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/terrarium/.bashrc \
    && echo 'export PATH="$HOME/.local/bin:$PATH"' >> /home/terrarium/.profile

# Configure Claude Code to use the Terrarium MCP server, skip onboarding, and trust the workspace
RUN echo '{"mcpServers":{"terrarium":{"command":"node","args":["/opt/terrarium/mcp-server/terrarium-mcp.js"],"type":"stdio"}},"hasCompletedOnboarding":true,"firstStartTime":"2025-01-01T00:00:00.000Z","numStartups":1,"projects":{"/home/terrarium/workspace":{"hasTrustDialogAccepted":true,"allowedTools":[],"hasCompletedProjectOnboarding":true}}}' > /home/terrarium/.claude.json

# Pre-approve all Terrarium MCP tools so the user isn't prompted
RUN mkdir -p /home/terrarium/.claude && \
    echo '{"permissions":{"allow":["mcp__terrarium__*"]}}' > /home/terrarium/.claude/settings.json

WORKDIR /home/terrarium/workspace

# Keep container alive; Claude Code sessions started on demand via nerdctl exec
CMD ["sleep", "infinity"]
